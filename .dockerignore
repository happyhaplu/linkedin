# ── Build Context Ignores ────────────────────────────────────────────────────
.git
.gitignore

# Go build artifacts
backend/bin/
backend/server
backend/*.exe

# Frontend dev artifacts
frontend/node_modules/
frontend/dist/
frontend/.vscode/

# Environment files (secrets — injected at runtime)
.env
.env.*
!.env.example
backend/.env
backend/.env.*

# Editor / OS
.vscode/
.idea/
.DS_Store
*.pem

# ── Root-level legacy files only (slash prefix = root only) ─────────────────
/*.md
/*.js
/*.ts
/*.sh
/*.sql
/*.csv
/scripts/
/migrations/
/lib/
/app/
/components/
/hooks/
/types/
/public/
/tests/
