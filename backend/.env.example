# Reach Backend — Environment
# Copy to .env and fill in real values.

# ── Server ──────────────────────────────────────────────────────────────────
PORT=4000

# ── PostgreSQL ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://reach:reach@localhost:5432/reach

# ── Accounts service (accounts.gour.io) ──────────────────────────────────────
# Public URL for browser redirects (login page, billing, sign-out)
ACCOUNTS_URL=https://accounts.gour.io
# Server-to-server API URL (can differ in Docker/k8s; defaults to ACCOUNTS_URL)
# ACCOUNTS_API_URL=http://accounts-internal:3001

# ── This app's own public URL ──────────────────────────────────────────────
APP_URL=http://localhost:4000

# ── JWT / Session ───────────────────────────────────────────────────────────
# MUST be set — shared signing secret between Reach and Accounts.
JWT_SECRET=change-me-in-production

# Cookie settings
SESSION_COOKIE=reach-session
SESSION_MAX_AGE=2592000
COOKIE_SECURE=false
COOKIE_SAMESITE=Lax

# ── Redis (for BullMQ campaign workers — not used by Go auth) ──────────────
REDIS_URL=redis://localhost:6379
