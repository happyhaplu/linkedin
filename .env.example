# ============================================================================
# Reach — Environment Variables
# ============================================================================
# Copy to .env and set your production values.
# In Coolify, set these in the service's Environment Variables tab.
# ============================================================================

# ── PostgreSQL (used by both postgres service and app) ──────────────────────
POSTGRES_DB=reach
POSTGRES_USER=reach
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── App Server ──────────────────────────────────────────────────────────────
PORT=4000

# ── Authentication ──────────────────────────────────────────────────────────
# Shared JWT signing secret between Reach and accounts.gour.io
JWT_SECRET=CHANGE_ME_RANDOM_64_CHARS

# External accounts service URL
ACCOUNTS_URL=https://accounts.gour.io
# ACCOUNTS_API_URL=  # Only set if internal URL differs from ACCOUNTS_URL

# ── Public URLs ─────────────────────────────────────────────────────────────
# Your domain where Reach is deployed (Coolify will set this)
APP_URL=https://reach.gour.io

FRONTEND_URL=https://reach.gour.io

# ── Session / Cookie ────────────────────────────────────────────────────────
SESSION_COOKIE=reach-session
SESSION_MAX_AGE=2592000
COOKIE_SECURE=true
COOKIE_SAMESITE=Lax
